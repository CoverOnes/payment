# Payment Service — Environment Configuration
# Copy to .env for local development. NEVER commit .env to git.
# All keys use PAYMENT_ prefix (CONVENTIONS §3).

# Required: Postgres DSN
PAYMENT_POSTGRES_DSN=postgres://payment_user:REPLACE_ME@localhost:5432/payment_db?sslmode=disable

# Optional: Postgres schema name for schema-per-service isolation (default: empty = public schema).
# Set to "payment" when sharing one Aiven database across multiple services.
# Each connection will run: SET search_path = <PAYMENT_DB_SCHEMA>
# Value must be [a-zA-Z0-9_]+ only.
#PAYMENT_DB_SCHEMA=

# Optional: Postgres connection pool sizing.
# Reduce PAYMENT_DB_MAX_CONNS when running many services against a small Aiven plan.
# PAYMENT_DB_MAX_CONNS must be >= PAYMENT_DB_MIN_CONNS (both default shown below).
#PAYMENT_DB_MAX_CONNS=10
#PAYMENT_DB_MIN_CONNS=2

# Optional: Redis URL (omit to use noop event publisher + in-process rate limiter)
PAYMENT_REDIS_URL=redis://localhost:6379

# Server port (default: 8084)
PAYMENT_PORT=8084

# Log level: DEBUG|INFO|WARN|ERROR (default: INFO)
PAYMENT_LOG_LEVEL=DEBUG

# Environment: development|staging|production. REQUIRED — no default.
# Operators MUST set this explicitly; empty/unknown value causes boot error.
PAYMENT_ENV=development

# Gateway-origin identity signature (conventions §24.1 — defense-in-depth)
# MUST equal the gateway's GATEWAY_HMAC_SECRET. ≥32 chars.
# Non-dev (staging/production): REQUIRED — boot fails fast if empty/short.
# Development: may be left empty (verification disabled, mirroring the gateway's
# dev signing-skip). chmod 0600 any file that provides this; env var is canonical.
PAYMENT_GATEWAY_HMAC_SECRET=REPLACE_ME_min32chars

# Settlement S2S token — bearer secret for the internal disburse endpoint.
# Trusted callers (workspace service) must supply this in X-Service-Token.
# Non-dev (staging/production): REQUIRED, ≥32 chars.
# Development: may be left empty; if set must be ≥32 chars.
# Generate with: openssl rand -base64 32
PAYMENT_SETTLEMENT_S2S_TOKEN=REPLACE_ME_min32chars

# Workspace service base URL — used for S2S calls (e.g. fetch frozen party roster).
# Non-dev (staging/production): REQUIRED, must use https:// scheme.
# Development: may be left empty (S2S call is skipped).
# Example: https://workspace.internal.coverones.com
PAYMENT_WORKSPACE_BASE_URL=http://workspace:8082

# Workspace S2S token — bearer secret sent in X-Service-Token when calling workspace.
# Non-dev (staging/production): REQUIRED, ≥32 chars.
# Development: may be left empty; if set must be ≥32 chars.
# Generate with: openssl rand -base64 32
PAYMENT_WORKSPACE_S2S_TOKEN=REPLACE_ME_min32chars

# Platform user UUID — used as PayerUserID in settlement disburse transactions.
# Ensures payer != payee (self-transfer guard). Must be a valid UUID.
# Non-dev (staging/production): REQUIRED.
# Development: may be left empty (zero UUID used as fallback).
# Generate with: uuidgen (macOS) or uuid-runtime (Linux)
PAYMENT_PLATFORM_USER_ID=REPLACE_ME_valid_uuid

# Per-authenticated-user rate limiter for the /v1 group (downstream gateway retrofit).
# Keyed on the VERIFIED user_id from the gateway-injected identity — never on the raw header.
# Must be mounted AFTER VerifyGatewaySignature+RequireValidIdentity so the key is derived
# from a verified context value, not an attacker-controlled header.
# Set to 0 to disable the per-user limiter entirely (IP-level rate limiter still applies).
# When enabled (> 0), PAYMENT_USER_RATE_LIMIT_BURST MUST also be > 0.
# Default: 120 req/min, burst 20.
#PAYMENT_USER_RATE_LIMIT_PER_MIN=120
#PAYMENT_USER_RATE_LIMIT_BURST=20
