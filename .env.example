# Payment Service — Environment Configuration
# Copy to .env for local development. NEVER commit .env to git.
# All keys use PAYMENT_ prefix (CONVENTIONS §3).

# Required: Postgres DSN
PAYMENT_POSTGRES_DSN=postgres://payment_user:REPLACE_ME@localhost:5432/payment_db?sslmode=disable

# Optional: Postgres schema name for schema-per-service isolation (default: empty = public schema).
# Set to "payment" when sharing one Aiven database across multiple services.
# Each connection will run: SET search_path = <PAYMENT_DB_SCHEMA>
# Value must be [a-zA-Z0-9_]+ only.
#PAYMENT_DB_SCHEMA=

# Optional: Redis URL (omit to use noop event publisher + in-process rate limiter)
PAYMENT_REDIS_URL=redis://localhost:6379

# Server port (default: 8084)
PAYMENT_PORT=8084

# Log level: DEBUG|INFO|WARN|ERROR (default: INFO)
PAYMENT_LOG_LEVEL=DEBUG

# Environment: development|production|test (default: development)
PAYMENT_ENV=development
